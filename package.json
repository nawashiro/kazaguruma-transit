    "nosskey-sdk": "^0.0.2",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-ga4": "^2.1.0",
    "react-icons": "^5.7.0",
    "react-to-print": "^3.0.5",
    "transit-departures-widget": "^2.5.4",
    "tsx": "^4.19.3",
    "webpack-license-plugin": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
