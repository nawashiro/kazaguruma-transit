  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && next dev --turbopack",
    "build": "prisma generate && prisma db push --accept-data-loss && npm run import-gtfs && next build",
    "start": "prisma generate && prisma db push --accept-data-loss && npm run import-gtfs && next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "check:no-nostr-tools": "node -e \"const p=require('./package.json');const has=(p.dependencies&&p.dependencies['nostr-tools'])||(p.devDependencies&&p.devDependencies['nostr-tools']);if(has){console.error('nostr-tools dependency detected');process.exit(1)}console.log('OK: nostr-tools is not declared in package.json')\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "import-gtfs": "tsx scripts/import-gtfs.ts"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.1",
    "@heroicons/react": "^2.2.0",
    "@nostr-dev-kit/ndk": "latest",
    "@prisma/client": "^6.6.0",
    "@react-pdf/renderer": "^4.3.0",
    "@types/luxon": "^3.4.2",
    "daisyui": "^5.0.50",
